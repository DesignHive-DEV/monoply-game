<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Wala - Play Business Simulation Game Online</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #1a1a2e;
            color: #fff;
            overflow: hidden;
        }

        /* Main Container */
        .game-container {
            display: flex;
            height: 100vh;
            width: 100vw;
            position: relative;
        }

        /* Left Sidebar */
        .left-sidebar {
            width: 280px;
            background: #16213e;
            border-right: 1px solid #0f3460;
            display: flex;
            flex-direction: column;
            padding: 20px 0;
        }

        .logo {
            padding: 0 20px 20px 20px;
            border-bottom: 1px solid #0f3460;
        }

        .logo h1 {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
        }

        .logo span {
            color: #e94560;
        }

        .players-list {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

        .players-list h3 {
            font-size: 14px;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .player-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: #1e2a47;
            border-radius: 8px;
            margin-bottom: 10px;
            border: 2px solid transparent;
            transition: all 0.2s;
        }

        .player-item.active {
            border-color: #e94560;
            background: #2a3a5e;
        }

        .player-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: white;
        }

        .player-avatar.red { background: #e94560; }
        .player-avatar.blue { background: #4361ee; }
        .player-avatar.green { background: #2a9d8f; }
        .player-avatar.yellow { background: #f8961e; }

        .player-info {
            flex: 1;
        }

        .player-name {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 4px;
        }

        .player-money {
            font-size: 13px;
            color: #4ade80;
            font-weight: 600;
        }

        .player-properties {
            font-size: 11px;
            color: #888;
        }

        /* Main Game Area */
        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #0f3460;
            position: relative;
            overflow: hidden;
        }

        /* Game Header */
        .game-header {
            padding: 15px 30px;
            background: #16213e;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #0f3460;
        }

        .room-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .room-code {
            background: #1e2a47;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .room-code:hover {
            background: #2a3a5e;
        }

        .room-code i {
            margin-right: 8px;
            color: #e94560;
        }

        .game-stats {
            display: flex;
            gap: 20px;
        }

        .stat {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .stat i {
            color: #e94560;
        }

        .header-buttons {
            display: flex;
            gap: 10px;
        }

        .header-btn {
            background: #1e2a47;
            border: none;
            color: white;
            padding: 8px 15px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }

        .header-btn:hover {
            background: #2a3a5e;
        }

        .header-btn.danger:hover {
            background: #e94560;
        }

        /* Game Board */
        .board-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
        }

        .board {
            display: grid;
            grid-template-columns: repeat(11, 1fr);
            gap: 2px;
            width: 100%;
            max-width: 900px;
            aspect-ratio: 1.8;
            background: #16213e;
            padding: 10px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .cell {
            background: #1e2a47;
            border-radius: 6px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            text-align: center;
            padding: 5px;
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
        }

        .cell:hover {
            background: #2a3a5e;
            transform: scale(1.02);
        }

        .cell.corner {
            background: #e94560;
            font-weight: 600;
        }

        .cell .icon {
            font-size: 16px;
            margin-bottom: 3px;
        }

        .cell .name {
            font-weight: 600;
            margin-bottom: 2px;
        }

        .cell .price {
            color: #4ade80;
            font-size: 9px;
        }

        .property-color {
            width: 100%;
            height: 4px;
            position: absolute;
            top: 0;
            left: 0;
            border-radius: 6px 6px 0 0;
        }

        .cell .owner-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            position: absolute;
            top: 2px;
            right: 2px;
        }

        .cell .players-on {
            position: absolute;
            bottom: 2px;
            right: 2px;
            display: flex;
            gap: 2px;
        }

        .player-token {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            border: 1px solid white;
        }

        .player-token.red { background: #e94560; }
        .player-token.blue { background: #4361ee; }
        .player-token.green { background: #2a9d8f; }
        .player-token.yellow { background: #f8961e; }

        /* Right Sidebar */
        .right-sidebar {
            width: 320px;
            background: #16213e;
            border-left: 1px solid #0f3460;
            display: flex;
            flex-direction: column;
        }

        /* Dice Section */
        .dice-section {
            padding: 20px;
            border-bottom: 1px solid #0f3460;
        }

        .dice-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
        }

        .dice {
            width: 70px;
            height: 70px;
            background: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 700;
            color: #1a1a2e;
            box-shadow: 0 5px 0 #0f3460;
        }

        .dice.rolling {
            animation: roll 0.2s linear infinite;
        }

        @keyframes roll {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .game-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .game-btn {
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
            background: #1e2a47;
            color: white;
        }

        .game-btn.primary {
            background: #e94560;
        }

        .game-btn.primary:hover:not(:disabled) {
            background: #d13d55;
            transform: translateY(-2px);
        }

        .game-btn:hover:not(:disabled) {
            background: #2a3a5e;
            transform: translateY(-2px);
        }

        .game-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Property Info */
        .property-info {
            flex: 1;
            padding: 20px;
            border-bottom: 1px solid #0f3460;
            overflow-y: auto;
        }

        .property-info h3 {
            font-size: 14px;
            color: #888;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .current-property {
            background: #1e2a47;
            border-radius: 12px;
            padding: 15px;
        }

        .prop-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .prop-name {
            font-size: 18px;
            font-weight: 700;
        }

        .prop-group {
            font-size: 12px;
            color: #888;
        }

        .prop-price {
            font-size: 24px;
            color: #4ade80;
            font-weight: 700;
            margin: 10px 0;
        }

        .prop-owner {
            margin: 10px 0;
            padding: 10px;
            background: #16213e;
            border-radius: 8px;
            font-size: 14px;
        }

        .rent-table {
            margin-top: 15px;
        }

        .rent-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #0f3460;
            font-size: 13px;
        }

        .prop-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 20px;
        }

        .prop-btn {
            padding: 10px;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .prop-btn.buy {
            background: #4ade80;
            color: #1a1a2e;
        }

        .prop-btn.sell {
            background: #f8961e;
            color: #1a1a2e;
        }

        .prop-btn.mortgage {
            background: #888;
            color: white;
        }

        /* Action Log */
        .action-log {
            padding: 20px;
            height: 200px;
            overflow-y: auto;
        }

        .action-log h3 {
            font-size: 14px;
            color: #888;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .log-entry {
            font-size: 12px;
            padding: 8px;
            border-bottom: 1px solid #0f3460;
            color: #ccc;
        }

        .log-entry:last-child {
            border-bottom: none;
        }

        /* Modal */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #16213e;
            border-radius: 20px;
            padding: 30px;
            max-width: 500px;
            width: 90%;
            border: 1px solid #0f3460;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-header h2 {
            font-size: 24px;
        }

        .modal-close {
            background: none;
            border: none;
            color: #888;
            font-size: 24px;
            cursor: pointer;
        }

        .modal-close:hover {
            color: #e94560;
        }

        /* Start Screen */
        .start-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
        }

        .start-card {
            background: #16213e;
            border-radius: 30px;
            padding: 50px;
            text-align: center;
            max-width: 450px;
            width: 90%;
            border: 1px solid #0f3460;
        }

        .start-card h1 {
            font-size: 48px;
            margin-bottom: 10px;
        }

        .start-card h1 span {
            color: #e94560;
        }

        .start-card p {
            color: #888;
            margin-bottom: 30px;
        }

        .start-input {
            width: 100%;
            padding: 15px;
            background: #1e2a47;
            border: 1px solid #0f3460;
            border-radius: 10px;
            color: white;
            font-size: 16px;
            margin-bottom: 15px;
        }

        .start-btn {
            width: 100%;
            padding: 15px;
            background: #e94560;
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 10px;
        }

        .start-btn:hover {
            background: #d13d55;
            transform: translateY(-2px);
        }

        .start-btn.secondary {
            background: #1e2a47;
        }

        .start-btn.secondary:hover {
            background: #2a3a5e;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .left-sidebar { width: 240px; }
            .right-sidebar { width: 280px; }
        }

        @media (max-width: 992px) {
            .game-container { flex-direction: column; }
            .left-sidebar, .right-sidebar { width: 100%; height: auto; }
            .board { max-width: 100%; }
        }
    </style>
</head>
<body>
    <!-- Start Screen -->
    <div class="start-screen" id="startScreen">
        <div class="start-card">
            <h1>Business<span>Wala</span></h1>
            <p>The ultimate business simulation game</p>
            <input type="text" class="start-input" id="playerName" placeholder="Your name" value="Player 1">
            <button class="start-btn" onclick="createGame()">
                <i class="fas fa-plus"></i> Create New Game
            </button>
            <button class="start-btn secondary" onclick="showJoinGame()">
                <i class="fas fa-door-open"></i> Join Game
            </button>
            <div id="joinGameDiv" style="display: none; margin-top: 20px;">
                <input type="text" class="start-input" id="roomCode" placeholder="Enter room code">
                <button class="start-btn" onclick="joinGame()">Join</button>
            </div>
        </div>
    </div>

    <!-- Main Game Container -->
    <div class="game-container" id="gameContainer" style="display: none;">
        <!-- Left Sidebar -->
        <div class="left-sidebar">
            <div class="logo">
                <h1>Business<span>Wala</span></h1>
            </div>
            
            <div class="players-list">
                <h3><i class="fas fa-users"></i> PLAYERS (4/4)</h3>
                <div id="playersList"></div>
            </div>
        </div>

        <!-- Main Game Area -->
        <div class="main-area">
            <div class="game-header">
                <div class="room-info">
                    <div class="room-code" onclick="copyRoomCode()">
                        <i class="fas fa-copy"></i> <span id="roomCodeDisplay">BW-1234</span>
                    </div>
                    <div class="game-stats">
                        <div class="stat">
                            <i class="fas fa-clock"></i>
                            <span id="turnIndicator">Player 1's turn</span>
                        </div>
                        <div class="stat">
                            <i class="fas fa-chart-line"></i>
                            <span id="roundCounter">Round 1</span>
                        </div>
                    </div>
                </div>
                <div class="header-buttons">
                    <button class="header-btn" onclick="openTradeModal()">
                        <i class="fas fa-exchange-alt"></i> Trade
                    </button>
                    <button class="header-btn danger" onclick="leaveGame()">
                        <i class="fas fa-sign-out-alt"></i> Leave
                    </button>
                </div>
            </div>

            <div class="board-container">
                <div class="board" id="board"></div>
            </div>
        </div>

        <!-- Right Sidebar -->
        <div class="right-sidebar">
            <div class="dice-section">
                <div class="dice-container">
                    <div class="dice" id="dice1">1</div>
                    <div class="dice" id="dice2">1</div>
                </div>
                <div class="game-buttons">
                    <button class="game-btn primary" id="rollBtn" onclick="rollDice()">
                        <i class="fas fa-dice"></i> Roll Dice
                    </button>
                    <button class="game-btn" id="endTurnBtn" onclick="endTurn()" disabled>
                        <i class="fas fa-check"></i> End Turn
                    </button>
                </div>
            </div>

            <div class="property-info">
                <h3><i class="fas fa-building"></i> PROPERTY INFO</h3>
                <div id="propertyInfo" class="current-property">
                    <div style="text-align: center; color: #888;">
                        Click on a property to view details
                    </div>
                </div>
            </div>

            <div class="action-log" id="actionLog">
                <h3><i class="fas fa-history"></i> GAME LOG</h3>
            </div>
        </div>
    </div>

    <!-- Trade Modal -->
    <div class="modal" id="tradeModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Trade</h2>
                <button class="modal-close" onclick="closeTradeModal()">&times;</button>
            </div>
            <div style="margin-bottom: 20px;">
                <select id="tradeWithPlayer" class="start-input">
                    <option value="">Select player to trade with</option>
                </select>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div>
                    <h4>Your Properties</h4>
                    <div id="yourTradeProps" style="max-height: 200px; overflow-y: auto;"></div>
                </div>
                <div>
                    <h4>Their Properties</h4>
                    <div id="theirTradeProps" style="max-height: 200px; overflow-y: auto;"></div>
                </div>
            </div>
            <div style="margin-bottom: 20px;">
                <label>Cash Offer:</label>
                <input type="number" id="cashOffer" class="start-input" placeholder="Enter amount">
            </div>
            <button class="start-btn" onclick="sendTradeOffer()">Send Offer</button>
        </div>
    </div>

