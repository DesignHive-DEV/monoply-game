            { id: 32, name: 'North Carolina Ave', price: 300, group: 7, rent: [26, 130, 390, 900, 1100, 1275], color: '#0000FF' },
            { id: 33, name: 'Community Chest', type: 'chest', icon: 'fa-question-circle' },
            { id: 34, name: 'Pennsylvania Ave', price: 320, group: 7, rent: [28, 150, 450, 1000, 1200, 1400], color: '#0000FF' },
            { id: 35, name: 'Short Line Railroad', price: 200, type: 'railroad', rent: [25, 50, 100, 200], color: '#000000' },
            { id: 36, name: 'Chance', type: 'chance', icon: 'fa-random' },
            { id: 37, name: 'Park Place', price: 350, group: 8, rent: [35, 175, 500, 1100, 1300, 1500], color: '#800080' },
            { id: 38, name: 'Luxury Tax', type: 'tax', icon: 'fa-coins' },
            { id: 39, name: 'Boardwalk', price: 400, group: 8, rent: [50, 200, 600, 1400, 1700, 2000], color: '#800080' }
        ];

        // Initialize game
        document.addEventListener('DOMContentLoaded', () => {
            initProperties();
        });

        function initProperties() {
            propertyData.forEach((data, index) => {
                gameState.properties.push({
                    ...data,
                    id: index,
                    owner: null,
                    houses: 0,
                    mortgaged: false
                });
            });
        }

        // Start Screen Functions
        function createGame() {
            const playerName = document.getElementById('playerName').value || 'Player 1';
            gameState.players[0].name = playerName;
            
            document.getElementById('startScreen').style.display = 'none';
            document.getElementById('gameContainer').style.display = 'flex';
            
            renderBoard();
            renderPlayers();
            updatePropertyInfo(null);
            addToLog('Game started! Room code: ' + gameState.roomCode);
            updateTurnDisplay();
        }

        function showJoinGame() {
            document.getElementById('joinGameDiv').style.display = 'block';
        }

        function joinGame() {
            const roomCode = document.getElementById('roomCode').value;
            if (roomCode) {
                gameState.roomCode = roomCode;
                document.getElementById('roomCodeDisplay').textContent = roomCode;
                createGame();
            }
        }

        function copyRoomCode() {
            navigator.clipboard.writeText(gameState.roomCode);
            addToLog('Room code copied to clipboard!');
        }

        function leaveGame() {
            if (confirm('Leave the game?')) {
                location.reload();
            }
        }

        // Board Rendering
        function renderBoard() {
            const board = document.getElementById('board');
            board.innerHTML = '';

            gameState.properties.forEach((prop, index) => {
                const cell = document.createElement('div');
                cell.className = 'cell';
                cell.onclick = () => showPropertyInfo(index);

                if (prop.type === 'corner' || prop.type === 'jail' || prop.type === 'parking' || prop.type === 'gotojail') {
                    cell.classList.add('corner');
                    cell.innerHTML = `
                        <i class="fas ${prop.icon} icon"></i>
                        <div class="name">${prop.name}</div>
                    `;
                } else if (prop.type === 'chest' || prop.type === 'chance' || prop.type === 'tax') {
                    cell.innerHTML = `
                        <i class="fas ${prop.icon} icon"></i>
                        <div class="name">${prop.name}</div>
                    `;
                } else {
                    const colorStyle = prop.color ? `style="background: ${prop.color}"` : '';
                    let ownerDot = '';
                    if (prop.owner !== null) {
                        const owner = gameState.players[prop.owner];
                        ownerDot = `<div class="owner-dot ${owner.color}"></div>`;
                    }

                    // Players on property
                    const playersOnProp = gameState.players.filter(p => p.position === index);
                    let playersHtml = '';
                    if (playersOnProp.length > 0) {
                        playersHtml = '<div class="players-on">';
                        playersOnProp.forEach(p => {
                            playersHtml += `<div class="player-token ${p.color}"></div>`;
                        });
                        playersHtml += '</div>';
                    }

                    cell.innerHTML = `
                        <div class="property-color" ${colorStyle}></div>
                        ${ownerDot}
                        <div class="name">${prop.name}</div>
                        <div class="price">$${prop.price}</div>
                        ${playersHtml}
                    `;
                }

                board.appendChild(cell);
            });
        }

        // Players List Rendering
        function renderPlayers() {
            const playersList = document.getElementById('playersList');
            playersList.innerHTML = '';

            gameState.players.forEach((player, index) => {
                const playerEl = document.createElement('div');
                playerEl.className = `player-item ${index === gameState.currentPlayer ? 'active' : ''}`;
                playerEl.innerHTML = `
                    <div class="player-avatar ${player.color}">${player.name.charAt(0)}</div>
                    <div class="player-info">
                        <div class="player-name">${player.name}</div>
                        <div class="player-money">$${player.money}</div>
                        <div class="player-properties">${player.properties.length} properties</div>
                    </div>
                `;
                playersList.appendChild(playerEl);
            });
        }

        // Dice Functions
        function rollDice() {
            if (gameState.diceRolled) return;

            const dice1 = document.getElementById('dice1');
            const dice2 = document.getElementById('dice2');
            const rollBtn = document.getElementById('rollBtn');
            const endTurnBtn = document.getElementById('endTurnBtn');

            // Animation
            dice1.classList.add('rolling');
            dice2.classList.add('rolling');

            setTimeout(() => {
                dice1.classList.remove('rolling');
                dice2.classList.remove('rolling');

                const d1 = Math.floor(Math.random() * 6) + 1;
                const d2 = Math.floor(Math.random() * 6) + 1;
                
                gameState.dice = [d1, d2];
                dice1.textContent = d1;
                dice2.textContent = d2;
                
                gameState.diceRolled = true;
                rollBtn.disabled = true;
                
                movePlayer(gameState.currentPlayer, d1 + d2);

                // Check for doubles
                if (d1 === d2) {
                    addToLog(`${gameState.players[gameState.currentPlayer].name} rolled doubles! Gets another turn`);
                    gameState.diceRolled = false;
                    rollBtn.disabled = false;
                    endTurnBtn.disabled = true;
                } else {
                    endTurnBtn.disabled = false;
                }

                addToLog(`${gameState.players[gameState.currentPlayer].name} rolled ${d1} + ${d2} = ${d1 + d2}`);
            }, 500);
        }

        function movePlayer(playerIndex, steps) {
            const player = gameState.players[playerIndex];
            const oldPos = player.position;
            const newPos = (oldPos + steps) % gameState.properties.length;
            
            player.position = newPos;

            // Passed GO
            if (newPos < oldPos) {
                player.money += 200;
                addToLog(`${player.name} passed GO and collected $200`);
            }

            // Handle landing
            const property = gameState.properties[newPos];
            
            if (property.type === 'tax') {
                const tax = property.name === 'Income Tax' ? 200 : 100;
                player.money -= tax;
                addToLog(`${player.name} paid $${tax} tax`);
            } else if (property.type === 'gotojail') {
                player.position = 10; // Jail position
                player.inJail = true;
                addToLog(`${player.name} goes to jail!`);
            } else if (property.owner !== null && property.owner !== playerIndex) {
                // Pay rent
                const owner = gameState.players[property.owner];
                const rent = calculateRent(property);
                
                if (player.money >= rent) {
                    player.money -= rent;
                    owner.money += rent;
                    addToLog(`${player.name} paid $${rent} rent to ${owner.name}`);
                } else {
                    // Bankruptcy
                    handleBankruptcy(playerIndex, property.owner);
                }
            }

            renderBoard();
            renderPlayers();
            showPropertyInfo(newPos);
            updateTurnDisplay();
        }

        function calculateRent(property) {
            if (property.type === 'railroad') {
                const ownerRailroads = gameState.properties.filter(p => 
                    p.owner === property.owner && p.type === 'railroad'
                ).length;
                return property.rent[ownerRailroads - 1] || 25;
            } else if (property.type === 'utility') {
                const ownerUtils = gameState.properties.filter(p => 
                    p.owner === property.owner && p.type === 'utility'
                ).length;
                const diceTotal = gameState.dice[0] + gameState.dice[1];
                return ownerUtils === 2 ? diceTotal * 10 : diceTotal * 4;
            }
            return property.rent[property.houses] || property.price;
        }

        function handleBankruptcy(playerIndex, ownerIndex) {
            const player = gameState.players[playerIndex];
            const owner = gameState.players[ownerIndex];

            // Transfer properties
            player.properties.forEach(propId => {
                const prop = gameState.properties[propId];
                prop.owner = ownerIndex;
                owner.properties.push(propId);
            });

            owner.money += player.money;
            player.money = 0;
            player.properties = [];

            addToLog(`${player.name} went bankrupt! All assets transferred to ${owner.name}`);
            
            if (playerIndex === 0) {
                alert('Game Over! You went bankrupt!');
                leaveGame();
            }
        }

        function endTurn() {
            gameState.currentPlayer = (gameState.currentPlayer + 1) % 4;
            
            if (gameState.currentPlayer === 0) {
                gameState.round++;
                document.getElementById('roundCounter').textContent = `Round ${gameState.round}`;
            }

            gameState.diceRolled = false;
            document.getElementById('rollBtn').disabled = false;
            document.getElementById('endTurnBtn').disabled = true;
            
            renderPlayers();
            updateTurnDisplay();
            addToLog(`${gameState.players[gameState.currentPlayer].name}'s turn`);
            
            // Check if in jail
            if (gameState.players[gameState.currentPlayer].inJail) {
                handleJail();
            }
        }

        function handleJail() {
            addToLog(`${gameState.players[gameState.currentPlayer].name} is in jail`);
            // Could add jail options here
        }

        // Property Info Display
        function showPropertyInfo(propId) {
            const prop = gameState.properties[propId];
            const infoDiv = document.getElementById('propertyInfo');
            
            if (prop.type === 'corner' || prop.type === 'jail' || prop.type === 'parking' || 
                prop.type === 'gotojail' || prop.type === 'chest' || prop.type === 'chance' || prop.type === 'tax') {
                infoDiv.innerHTML = `
                    <div style="text-align: center;">
                        <i class="fas ${prop.icon}" style="font-size: 40px; color: #888; margin-bottom: 10px;"></i>
                        <h3 style="margin-bottom: 10px;">${prop.name}</h3>
                        <p style="color: #888;">${prop.type === 'tax' ? 'Pay tax when you land here' : 'Special space'}</p>
                    </div>
                `;
                return;
            }

            const owner = prop.owner !== null ? gameState.players[prop.owner].name : 'Available';
            const ownerColor = prop.owner !== null ? gameState.players[prop.owner].color : '';
            
            let rentHtml = '<div class="rent-table">';
            if (prop.rent) {
                const labels = ['Base', '1 House', '2 Houses', '3 Houses', '4 Houses', 'Hotel'];
                prop.rent.forEach((rent, i) => {
                    rentHtml += `
                        <div class="rent-row">
                            <span>${labels[i]}</span>
                            <span>$${rent}</span>
                        </div>
                    `;
                });
            }
            rentHtml += '</div>';

            let actions = '';
            const currentPlayer = gameState.players[gameState.currentPlayer];
            
            if (prop.owner === null && currentPlayer.money >= prop.price && gameState.diceRolled) {
                actions += `<button class="prop-btn buy" onclick="buyProperty(${propId})">Buy $${prop.price}</button>`;
            }
            
            if (prop.owner === gameState.currentPlayer) {
                actions += `<button class="prop-btn sell" onclick="sellProperty(${propId})">Sell</button>`;
                actions += `<button class="prop-btn mortgage" onclick="mortgageProperty(${propId})">Mortgage</button>`;
            }

            infoDiv.innerHTML = `
                <div class="prop-header">
                    <span class="prop-name">${prop.name}</span>
                    <span class="prop-group">Group ${prop.group || ''}</span>
                </div>
                <div class="prop-price">$${prop.price}</div>
                <div class="prop-owner">
                    <strong>Owner:</strong> <span style="color: ${ownerColor}">${owner}</span>
                </div>
                ${rentHtml}
                ${actions ? `<div class="prop-actions">${actions}</div>` : ''}
            `;
        }

        function updatePropertyInfo(prop) {
            if (prop === null) {
                document.getElementById('propertyInfo').innerHTML = `
                    <div style="text-align: center; color: #888;">
                        Click on a property to view details
                    </div>
                `;
            }
        }

        // Property Actions
        function buyProperty(propId) {
            const player = gameState.players[gameState.currentPlayer];
            const prop = gameState.properties[propId];
            
            if (player.money >= prop.price) {
                player.money -= prop.price;
                prop.owner = gameState.currentPlayer;
                player.properties.push(propId);
                
                addToLog(`${player.name} bought ${prop.name} for $${prop.price}`);
                renderPlayers();
                showPropertyInfo(propId);
                renderBoard();
            }
        }

        function sellProperty(propId) {
            const player = gameState.players[gameState.currentPlayer];
            const prop = gameState.properties[propId];
            const sellPrice = Math.floor(prop.price * 0.5);
            
            player.money += sellPrice;
            prop.owner = null;
            player.properties = player.properties.filter(id => id !== propId);
            
            addToLog(`${player.name} sold ${prop.name} for $${sellPrice}`);
            renderPlayers();
            showPropertyInfo(propId);
            renderBoard();
        }

        function mortgageProperty(propId) {
            const player = gameState.players[gameState.currentPlayer];
            const prop = gameState.properties[propId];
            const mortgageValue = Math.floor(prop.price * 0.4);
            
            player.money += mortgageValue;
            prop.mortgaged = true;
            
            addToLog(`${player.name} mortgaged ${prop.name} for $${mortgageValue}`);
            renderPlayers();
            showPropertyInfo(propId);
        }

        // Trade Functions
        function openTradeModal() {
            const modal = document.getElementById('tradeModal');
            const select = document.getElementById('tradeWithPlayer');
            
            select.innerHTML = '<option value="">Select player to trade with</option>';
            gameState.players.forEach((player, index) => {
                if (index !== gameState.currentPlayer) {
                    select.innerHTML += `<option value="${index}">${player.name}</option>`;
                }
            });

            updateTradeProperties();
            modal.classList.add('active');
        }

        function updateTradeProperties() {
            const yourProps = document.getElementById('yourTradeProps');
            const currentPlayer = gameState.players[gameState.currentPlayer];
            
            yourProps.innerHTML = '';
            currentPlayer.properties.forEach(propId => {
                const prop = gameState.properties[propId];
                yourProps.innerHTML += `
                    <div style="padding: 8px; border-bottom: 1px solid #0f3460;">
                        <input type="checkbox" class="your-prop" value="${propId}">
                        ${prop.name} ($${prop.price})
                    </div>
                `;
            });

            const theirProps = document.getElementById('theirTradeProps');
            const selectedPlayer = document.getElementById('tradeWithPlayer').value;
            
            if (selectedPlayer) {
                const player = gameState.players[selectedPlayer];
                theirProps.innerHTML = '';
                player.properties.forEach(propId => {
                    const prop = gameState.properties[propId];
                    theirProps.innerHTML += `
                        <div style="padding: 8px; border-bottom: 1px solid #0f3460;">
                            <input type="checkbox" class="their-prop" value="${propId}">
                            ${prop.name} ($${prop.price})
                        </div>
                    `;
                });
            }
        }

        function closeTradeModal() {
            document.getElementById('tradeModal').classList.remove('active');
        }

        function sendTradeOffer() {
            addToLog('Trade offer sent');
            alert('Trade feature - In a real game, this would send an offer to the other player');
            closeTradeModal();
        }

        // Action Log
        function addToLog(message) {
            gameState.actionLog.unshift(message);
            if (gameState.actionLog.length > 10) {
                gameState.actionLog.pop();
            }

            const logDiv = document.getElementById('actionLog');
            logDiv.innerHTML = '<h3><i class="fas fa-history"></i> GAME LOG</h3>';
            
            gameState.actionLog.forEach(entry => {
                const logEntry = document.createElement('div');
                logEntry.className = 'log-entry';
                logEntry.textContent = entry;
                logDiv.appendChild(logEntry);
            });
        }

        function updateTurnDisplay() {
            document.getElementById('turnIndicator').textContent = 
                `${gameState.players[gameState.currentPlayer].name}'s turn`;
        }

        // Keyboard Shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.code === 'Space' && !gameState.diceRolled) {
                e.preventDefault();
                rollDice();
            } else if (e.code === 'Enter' && gameState.diceRolled) {
                e.preventDefault();
                endTurn();
            }
        });
    </script>
</body>
</html>
